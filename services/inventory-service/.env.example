APP_NAME="Inventory Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8083
APP_PORT=8083

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=saas_inventory
DB_USERNAME=root
DB_PASSWORD=rootpassword

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MESSAGE_BROKER_DRIVER=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=password
RABBITMQ_VHOST=/

KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=inventory-consumer

AUTH_SERVICE_URL=http://auth-service:8081
TENANT_SERVICE_URL=http://tenant-service:8082
SAGA_SERVICE_URL=http://saga-orchestrator:8086

PASSPORT_AUTH_URL=http://auth-service:8081
PASSPORT_TOKEN_PATH=/oauth/token

PASSPORT_CLIENT_ID=
PASSPORT_CLIENT_SECRET=
